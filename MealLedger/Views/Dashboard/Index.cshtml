@model MealLedger.DTO.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = $"Welcome back, {Model.FullName}!";
    ViewData["ActivePage"] = "Dashboard";

    var today = Model.Today;
    //var today = new DateTime(2026, 3, 21).Date; // ← change this to test different days
    var isAdmin = Model.Role == "Admin";

    // Week days Mon–Fri
    int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
    var weekStart = today.AddDays(-diff);
    var weekDays = Enumerable.Range(0, 5).Select(i => weekStart.AddDays(i)).ToList();

    // ── Smart Status Logic ──
    var now = DateTime.Now;
    var cutoffTime = today.Date.AddHours(16);
    var isPastCutoff = now >= cutoffTime;
    var tomorrow = today.AddDays(1);

    // ── FIX: Check if TODAY is a weekend or holiday ──
    var isTodayWeekend = today.DayOfWeek == DayOfWeek.Saturday || today.DayOfWeek == DayOfWeek.Sunday;
    // (add company holiday check here if you have that list on DashboardViewModel)
    // var isTodayHoliday = Model.CompanyHolidays?.Contains(today.Date) ?? false;
    // var isTodayWeekendOrHoliday = isTodayWeekend || isTodayHoliday;
    var isTodayWeekendOrHoliday = isTodayWeekend;

    // Find next working day after today
    DateTime nextWorkingDay = tomorrow;
    while (
        nextWorkingDay.DayOfWeek == DayOfWeek.Saturday ||
        nextWorkingDay.DayOfWeek == DayOfWeek.Sunday
    )
    {
        nextWorkingDay = nextWorkingDay.AddDays(1);
    }

    var isTomorrowWeekendOrHoliday = nextWorkingDay.Date != tomorrow.Date;

    // Check registrations
    var isTodayRegistered = Model.IsTodayRegistered;

    var isTomorrowRegistered = Model.ThisWeekRegistrations != null &&
        Model.ThisWeekRegistrations.Any(r => r.LunchDate.Date == nextWorkingDay.Date);

    // Find next available day after next working day (for after 4PM closed case)
    DateTime nextAvailableDay = nextWorkingDay.AddDays(1);
    while (
        nextAvailableDay.DayOfWeek == DayOfWeek.Saturday ||
        nextAvailableDay.DayOfWeek == DayOfWeek.Sunday
    )
    {
        nextAvailableDay = nextAvailableDay.AddDays(1);
    }

    // Status variables
    string statusTitle;
    string statusSubtitle;
    string statusIcon;
    string statusDotClass;

    // ── FIX: Handle weekend/holiday TODAY first, before any other checks ──
    if (isTodayWeekendOrHoliday)
    {
        var todayLabel = isTodayWeekend
            ? (today.DayOfWeek == DayOfWeek.Saturday ? "Saturday" : "Sunday")
            : "today";

        if (isTomorrowRegistered)
        {
            // Weekend today, but already registered for next working day
            statusTitle = $"Today is a weekend 🎉 — You're all set!";
            statusSubtitle = $"Registered for {nextWorkingDay:dddd, dd MMM yyyy}";
            statusIcon = "fa-check";
            statusDotClass = "yes";
        }
        else
        {
            // Weekend today, not registered for next working day
            var nextDayLabel = tomorrow.DayOfWeek == DayOfWeek.Saturday || tomorrow.DayOfWeek == DayOfWeek.Sunday
                ? "weekend" : "working day";
            statusTitle = $"Today is {today.DayOfWeek} — enjoy your weekend! 🎉";
            statusSubtitle = $"Next working day: {nextWorkingDay:dddd, dd MMM yyyy} — register your lunch!";
            statusIcon = "fa-calendar-week";
            statusDotClass = "blue";
        }
    }
    else if (!isPastCutoff)
    {
        // ── Before 4 PM, today is a working day ──
        if (isTodayRegistered)
        {
            // State 1 — Registered today
            statusTitle = "You're registered for today's lunch ✅";
            statusSubtitle = today.ToString("dddd, dd MMM yyyy");
            statusIcon = "fa-check";
            statusDotClass = "yes";
        }
        else if (isTomorrowRegistered)
        {
            // State 2 — Not today but registered for next working day
            statusTitle = "You're registered for tomorrow's lunch ✅";
            statusSubtitle = $"{nextWorkingDay:dddd, dd MMM yyyy} — today's lunch was skipped";
            statusIcon = "fa-check";
            statusDotClass = "yes";
        }
        else
        {
            // State 3 — Not registered at all
            statusTitle = "Not registered for today's lunch";
            statusSubtitle = isTomorrowWeekendOrHoliday
                ? $"{today:dddd, dd MMM yyyy} — next working day: {nextWorkingDay:dddd, dd MMM}"
                : $"{today:dddd, dd MMM yyyy} — register for tomorrow!";
            statusIcon = "fa-clock";
            statusDotClass = "no";
        }
    }
    else if (isTomorrowWeekendOrHoliday)
    {
        // ── After 4 PM + Tomorrow is weekend/holiday ──
        if (isTomorrowRegistered)
        {
            // State 8 — Next working day registered
            statusTitle = $"You're registered for {nextWorkingDay:dddd, dd MMM}! ✅";
            statusSubtitle = "Next working day — you're all set!";
            statusIcon = "fa-check";
            statusDotClass = "yes";
        }
        else
        {
            // State 6 & 7 — Weekend/holiday tomorrow, not registered
            var tomorrowLabel = tomorrow.DayOfWeek == DayOfWeek.Saturday ||
                                tomorrow.DayOfWeek == DayOfWeek.Sunday
                                ? "weekend 🎉" : "company holiday 🎉";
            statusTitle = $"Tomorrow is a {tomorrowLabel}";
            statusSubtitle = $"Next working day: {nextWorkingDay:dddd, dd MMM yyyy} — register your lunch!";
            statusIcon = "fa-calendar-week";
            statusDotClass = "blue";
        }
    }
    else
    {
        // ── After 4 PM + Tomorrow is a working day ──
        if (isTomorrowRegistered)
        {
            // State 4 — Tomorrow registered
            statusTitle = "You're registered for tomorrow's lunch ✅";
            statusSubtitle = "You can still register for future dates";
            statusIcon = "fa-check";
            statusDotClass = "yes";
        }
        else
        {
            // State 5 — Tomorrow not registered, window closed
            statusTitle = "Today's registration window is now closed ❌";
            statusSubtitle = "You can still register for future dates";
            statusIcon = "fa-circle-xmark";
            statusDotClass = "red";
        }
    }
}

@section Styles {
    <style>
        .greeting-card {
            background: linear-gradient(135deg, #2d1b69 0%, #5b21b6 60%, #7c3aed 100%);
            border-radius: 18px;
            padding: 32px 36px;
            color: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

            .greeting-card::before {
                content: '';
                position: absolute;
                width: 220px;
                height: 220px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                top: -60px;
                right: -60px;
            }

            .greeting-card::after {
                content: '';
                position: absolute;
                width: 140px;
                height: 140px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                bottom: -40px;
                right: 120px;
            }

        .greeting-text h2 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .greeting-text p {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            margin: 0;
        }

        .greeting-badge {
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            padding: 12px 20px;
            text-align: center;
            z-index: 1;
        }

            .greeting-badge .day {
                font-size: 28px;
                font-weight: 700;
                line-height: 1;
            }

            .greeting-badge .month {
                font-size: 13px;
                color: rgba(255,255,255,0.7);
                margin-top: 4px;
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 18px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 22px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(91,33,182,0.12);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

            .stat-icon.purple {
                background: #ede9fe;
                color: #7c3aed;
            }

            .stat-icon.green {
                background: #dcfce7;
                color: #16a34a;
            }

            .stat-icon.orange {
                background: #fff7ed;
                color: #ea580c;
            }

            .stat-icon.blue {
                background: #eff6ff;
                color: #2563eb;
            }

        .stat-info .value {
            font-size: 26px;
            font-weight: 700;
            color: #1e1b4b;
            line-height: 1;
        }

        .stat-info .label {
            font-size: 12.5px;
            color: #8b7ec8;
            margin-top: 4px;
        }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #1e1b4b;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-title i {
                color: #7c3aed;
                font-size: 15px;
            }

        .week-strip {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
            margin-bottom: 28px;
        }

        .week-days {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .week-day {
            flex: 1;
            min-width: 80px;
            border-radius: 14px;
            padding: 16px 10px;
            text-align: center;
            border: 2px solid #ede9fe;
            background: #faf9ff;
            transition: all 0.2s;
        }

            .week-day.registered {
                background: linear-gradient(135deg, #5b21b6, #7c3aed);
                border-color: #7c3aed;
                color: white;
                box-shadow: 0 4px 14px rgba(124,58,237,0.3);
            }

            .week-day.today-day {
                border-color: #c4b5fd;
                background: #ede9fe;
            }

            .week-day.past-day {
                opacity: 0.5;
            }

            .week-day .day-name {
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: inherit;
                opacity: 0.7;
                margin-bottom: 6px;
            }

            .week-day .day-num {
                font-size: 20px;
                font-weight: 700;
                color: inherit;
                line-height: 1;
                margin-bottom: 8px;
            }

            .week-day .day-status {
                font-size: 11px;
                font-weight: 600;
            }

            .week-day.registered .day-name,
            .week-day.registered .day-status {
                color: rgba(255,255,255,0.85);
            }

            .week-day:not(.registered) .day-name {
                color: #8b7ec8;
            }

            .week-day:not(.registered) .day-num {
                color: #1e1b4b;
            }

            .week-day:not(.registered) .day-status {
                color: #a89fd8;
            }

        .status-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }

        .status-info {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .status-dot {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

            .status-dot.yes {
                background: #dcfce7;
                color: #16a34a;
            }

            .status-dot.no {
                background: #fef3c7;
                color: #d97706;
            }

            .status-dot.red {
                background: #fef2f2;
                color: #dc2626;
            }

            .status-dot.blue {
                background: #eff6ff;
                color: #2563eb;
            }

        .status-text .title {
            font-size: 16px;
            font-weight: 700;
            color: #1e1b4b;
        }

        .status-text .sub {
            font-size: 13px;
            color: #8b7ec8;
            margin-top: 3px;
        }

        .btn-schedule {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            background: linear-gradient(135deg, #4a2d9c, #7c3aed);
            color: white;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            white-space: nowrap;
        }

            .btn-schedule:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(124,58,237,0.35);
                color: white;
                text-decoration: none;
            }

        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 18px;
            margin-bottom: 28px;
        }

        .admin-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
            text-align: center;
        }

            .admin-card .big-num {
                font-size: 48px;
                font-weight: 700;
                color: #1e1b4b;
                line-height: 1;
                margin-bottom: 8px;
            }

            .admin-card .big-label {
                font-size: 13px;
                color: #8b7ec8;
                font-weight: 500;
            }

            .admin-card.veg .big-num {
                color: #16a34a;
            }

            .admin-card.nonveg .big-num {
                color: #ea580c;
            }

        @@media (max-width: 600px) {
            .greeting-card {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }

            .week-days {
                gap: 8px;
            }

            .week-day {
                min-width: 55px;
                padding: 12px 6px;
            }

                .week-day .day-num {
                    font-size: 16px;
                }

            .status-card {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<!-- Greeting Card -->
<div class="greeting-card">
    <div class="greeting-text">
        <h2>Hello, @Model.FullName.Split(' ')[0]! 👋</h2>
        <p>@(isAdmin ? "Here's today's lunch summary for " + Model.Location : "Here's your lunch schedule for this week.")</p>
    </div>
    <div class="greeting-badge">
        <div class="day">@today.Day</div>
        <div class="month">@today.ToString("MMM yyyy")</div>
    </div>
</div>

@if (isAdmin)
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fa-solid fa-users"></i></div>
            <div class="stat-info">
                <div class="value">@Model.TotalRegisteredToday</div>
                <div class="label">Total Registered Today</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-leaf"></i></div>
            <div class="stat-info">
                <div class="value">@Model.VegCountToday</div>
                <div class="label">Veg Today</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fa-solid fa-drumstick-bite"></i></div>
            <div class="stat-info">
                <div class="value">@Model.NonVegCountToday</div>
                <div class="label">Non-Veg Today</div>
            </div>
        </div>
    </div>

    <div class="status-card">
        <div class="status-info">
            <div class="status-dot yes"><i class="fa-solid fa-print"></i></div>
            <div class="status-text">
                <div class="title">Ready to print today's sheet?</div>
                <div class="sub">@today.ToString("dddd, dd MMM yyyy") — @Model.Location</div>
            </div>
        </div>
        <a href="@Url.Action("Index", "Admin")" class="btn-schedule">
            <i class="fa-solid fa-shield-halved"></i> Go to Admin Panel
        </a>
    </div>
}
else
{
    <!-- Smart Status Card -->
    <div class="status-card">
        <div class="status-info">
            <div class="status-dot @statusDotClass">
                <i class="fa-solid @statusIcon"></i>
            </div>
            <div class="status-text">
                <div class="title">@statusTitle</div>
                <div class="sub">@statusSubtitle</div>
            </div>
        </div>
        <a href="@Url.Action("Schedule", "Lunch")" class="btn-schedule">
            <i class="fa-solid fa-calendar-plus"></i> Register Lunch
        </a>
    </div>

    <!-- This Week Strip -->
    <div class="week-strip">
        <div class="section-title">
            <i class="fa-solid fa-calendar-week"></i>
            This Week's Schedule
        </div>
        <div class="week-days">
            @foreach (var day in weekDays)
            {
                var isToday = day.Date == today.Date;
                var isPast = day.Date < today.Date;
                var isRegistered = Model.ThisWeekRegistrations != null &&
                Model.ThisWeekRegistrations.Any(r => r.LunchDate.Date == day.Date);
                var cssClass = isRegistered ? "registered"
                : isToday ? "today-day"
                : isPast ? "past-day"
                : "";

                <div class="week-day @cssClass">
                    <div class="day-name">@day.ToString("ddd")</div>
                    <div class="day-num">@day.Day</div>
                    <div class="day-status">
                        @if (isRegistered)
                        {
                            <i class="fa-solid fa-check"></i>
                        }
                        else if (isPast)
                        {

                            <i class="fa-solid fa-xmark"></i>
                        }
                        else
                        {

                            <span>—</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            setTimeout(function () { location.reload(); }, 300000);
        });
    </script>
}
