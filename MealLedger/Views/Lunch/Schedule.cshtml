@model MealLedger.DTO.LunchScheduleViewModel

@{
    ViewData["Title"] = "Lunch Schedule";
    ViewData["Subtitle"] = "Select your lunch days";
    ViewData["ActivePage"] = "Lunch";

    var today = DateTime.Today;
    // var today = new DateTime(2026, 3, 22).Date;
    var currentMonth = Model.CurrentMonth;
    var currentYear = Model.CurrentYear;
    var firstDay = new DateTime(currentYear, currentMonth, 1);
    var daysInMonth = DateTime.DaysInMonth(currentYear, currentMonth);
    int startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
    var prevMonth = firstDay.AddMonths(-1);
    var nextMonth = firstDay.AddMonths(1);

    // ── Banner Logic ──
    var now = DateTime.Now;
    var cutoffTime = today.Date.AddHours(16);
    var isPastCutoff = now >= cutoffTime;

    var companyHolidayDates = Model.Holidays
        .Where(h => h.Type == "Company")
        .Select(h => DateTime.Parse(h.Date).Date)
        .ToList();

    // ── FIX: Properly check if tomorrow is a weekend or holiday ──
    var tomorrow = today.AddDays(1);
    var isTomorrowWeekendOrHoliday =
        tomorrow.DayOfWeek == DayOfWeek.Saturday ||
        tomorrow.DayOfWeek == DayOfWeek.Sunday ||
        companyHolidayDates.Contains(tomorrow.Date);

    // ── Next working day: if past cutoff, skip tomorrow too ──
    DateTime nextWorkingDay = isPastCutoff ? today.AddDays(2) : today.AddDays(1);
    while (
        nextWorkingDay.DayOfWeek == DayOfWeek.Saturday ||
        nextWorkingDay.DayOfWeek == DayOfWeek.Sunday ||
        companyHolidayDates.Contains(nextWorkingDay.Date)
    )
    {
        nextWorkingDay = nextWorkingDay.AddDays(1);
    }

    var isNextDayRegistered = Model.RegisteredDays
        .Any(r => r.Date == nextWorkingDay.ToString("yyyy-MM-dd"));

    DateTime nextAvailableDay = nextWorkingDay;
    while (
        Model.RegisteredDays.Any(r => r.Date == nextAvailableDay.ToString("yyyy-MM-dd")) ||
        nextAvailableDay.DayOfWeek == DayOfWeek.Saturday ||
        nextAvailableDay.DayOfWeek == DayOfWeek.Sunday ||
        companyHolidayDates.Contains(nextAvailableDay.Date)
    )
    {
        nextAvailableDay = nextAvailableDay.AddDays(1);
    }

    var minutesLeft = (int)(cutoffTime - now).TotalMinutes;
    var hoursLeft = minutesLeft / 60;
    var minsLeft = minutesLeft % 60;

    // ── Only say "tomorrow" when tomorrow IS the next working day ──
    var isTomorrowNextWorkingDay = !isTomorrowWeekendOrHoliday && !isPastCutoff;
}

@section Styles {
