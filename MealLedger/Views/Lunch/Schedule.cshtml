@model MealLedger.DTO.LunchScheduleViewModel

@{
    ViewData["Title"] = "Lunch Schedule";
    ViewData["Subtitle"] = "Select your lunch days";
    ViewData["ActivePage"] = "Lunch";

    var today = DateTime.Today;
    var currentMonth = Model.CurrentMonth;
    var currentYear = Model.CurrentYear;
    var firstDay = new DateTime(currentYear, currentMonth, 1);
    var daysInMonth = DateTime.DaysInMonth(currentYear, currentMonth);
    int startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
    var prevMonth = firstDay.AddMonths(-1);
    var nextMonth = firstDay.AddMonths(1);
}

@section Styles {
    <style>
        /* ── Delete button ── */
        .delete-btn {
            width: 22px;
            height: 22px;
            border-radius: 5px;
            border: none;
            background: #fef2f2;
            color: #dc2626;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            flex-shrink: 0;
            transition: all 0.15s;
        }

            .delete-btn:hover {
                background: #fee2e2;
                transform: scale(1.1);
            }

        /* ── Confirm box ── */
        .confirm-box {
            margin-top: 8px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 11px;
            color: #dc2626;
            justify-content:center;
            width: 40%;
            text-align: center;
            align-content:center;
        }

        .confirm-yes {
            padding: 4px 10px;
            background: #dc2626;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.15s;
            justify-content:center;
        }

            .confirm-yes:hover {
                background: #b91c1c;
            }

        .confirm-no {
            padding: 4px 10px;
            background: white;
            color: #6b7280;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.15s;
        }

            .confirm-no:hover {
                background: #f9fafb;
            }

        /* ── Badges ── */
        .edit-badge {
            font-size: 10px;
            font-weight: 600;
            color: #15803d;
            background: #dcfce7;
            border-radius: 4px;
            padding: 1px 6px;
            display: inline-block;
            margin-top: 2px;
        }

        .new-badge {
            font-size: 10px;
            font-weight: 600;
            color: #5b21b6;
            background: #ede9fe;
            border-radius: 4px;
            padding: 1px 6px;
            display: inline-block;
            margin-top: 2px;
        }

        .schedule-wrapper {
            display: grid;
            grid-template-columns: 580px 1fr;
            gap: 18px;
            align-items: start;
        }

        /* ── Calendar Card ── */
        .calendar-card {
            background: white;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
            max-width: 580px;
        }

        .calendar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

            .calendar-header h3 {
                font-size: 15px;
                font-weight: 700;
                color: #1e1b4b;
            }

        .nav-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            border: 1px solid #ede9fe;
            background: white;
            color: #5b21b6;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            transition: all 0.2s;
            text-decoration: none;
        }

            .nav-btn:hover {
                background: #ede9fe;
                border-color: #7c3aed;
                color: #7c3aed;
                text-decoration: none;
            }

        .day-names {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            margin-bottom: 6px;
        }

        .day-name-label {
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            color: #8b7ec8;
            padding: 4px 0;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
        }

        /* ── Day Cells ── */
        .cal-day {
            aspect-ratio: 1;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
            border: 1.5px solid transparent;
            transition: all 0.15s;
            position: relative;
            user-select: none;
            cursor: pointer;
            /* max-height: 52px; */
        }

            .cal-day.empty {
                background: transparent;
                cursor: default;
                border: none;
            }

            .cal-day.available {
                background: #faf9ff;
                border-color: #ede9fe;
                color: #1e1b4b;
            }

                .cal-day.available:hover {
                    background: #ede9fe;
                    border-color: #7c3aed;
                    color: #5b21b6;
                    transform: scale(1.05);
                }

            .cal-day.selected {
                background: linear-gradient(135deg, #4a2d9c, #7c3aed);
                border-color: #7c3aed;
                color: white;
                box-shadow: 0 3px 10px rgba(124,58,237,0.3);
                transform: scale(1.05);
            }

            .cal-day.registered {
                background: #dcfce7;
                border-color: #16a34a;
                color: #15803d;
            }

                .cal-day.registered:hover {
                    background: #bbf7d0;
                    transform: scale(1.05);
                }

            .cal-day.registered-selected {
                background: linear-gradient(135deg, #14532d, #16a34a);
                border-color: #15803d;
                color: white;
                box-shadow: 0 3px 10px rgba(22,163,74,0.3);
                transform: scale(1.05);
            }

            .cal-day.company-holiday {
                background: #fef2f2;
                border-color: #fecaca;
                color: #dc2626;
                cursor: not-allowed;
            }

            .cal-day.optional-holiday {
                background: #fffbeb;
                border-color: #fde68a;
                color: #d97706;
            }

                .cal-day.optional-holiday:hover {
                    background: #fef3c7;
                    transform: scale(1.05);
                }

            .cal-day.past {
                background: transparent;
                border-color: transparent;
                color: #d1d5db;
                cursor: not-allowed;
            }

            .cal-day.weekend {
                background: transparent;
                color: #e5e7eb;
                cursor: not-allowed;
                border-color: transparent;
            }

            .cal-day.today-day {
                background: #f3f4f6;
                border-color: #d1d5db;
                color: #9ca3af;
                cursor: not-allowed;
            }

        .pref-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            margin-top: 2px;
        }

            .pref-dot.veg {
                background: #16a34a;
            }

            .pref-dot.nonveg {
                background: #ea580c;
            }

        .cal-day.selected .pref-dot,
        .cal-day.registered-selected .pref-dot {
            background: white;
        }

        /* ── Right Panel ── */
        .right-panel {
            display: flex;
            flex-direction: column;
            gap: 12px;
            position: sticky;
            top: 20px;
        }

        .panel-card {
            background: white;
            border-radius: 14px;
            padding: 14px 16px;
            box-shadow: 0 2px 12px rgba(91,33,182,0.07);
            border: 1px solid #ede9fe;
        }

        .panel-title {
            font-size: 11px;
            font-weight: 700;
            color: #5b21b6;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 5px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

            .panel-title i {
                font-size: 11px;
            }

        /* ── Compact Legend ── */
        .legend-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px 8px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: #6b7280;
        }

        .legend-box {
            width: 14px;
            height: 14px;
            border-radius: 4px;
            flex-shrink: 0;
            border: 1.5px solid transparent;
        }

        /* ── Selected Days List ── */
        .selected-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
            max-height: 260px;
            overflow-y: auto;
            padding-right: 2px;
        }

            .selected-list::-webkit-scrollbar {
                width: 3px;
            }

            .selected-list::-webkit-scrollbar-thumb {
                background: #ede9fe;
                border-radius: 4px;
            }

        .selected-row {
            display: flex;
            align-items: center;
            gap: 5px;
            background: #faf9ff;
            border: 1px solid #ede9fe;
            border-radius: 8px;
            padding: 7px 9px;
            animation: slideIn 0.18s ease;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .selected-date-label {
            flex: 1;
            font-size: 11px;
            font-weight: 600;
            color: #1e1b4b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .pref-toggle {
            display: flex;
            border-radius: 6px;
            overflow: hidden;
            border: 1px solid #ede9fe;
            flex-shrink: 0;
        }

        .pref-toggle-btn {
            padding: 3px 6px;
            font-size: 10px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            background: white;
            color: #8b7ec8;
            transition: all 0.15s;
            white-space: nowrap;
            font-family: inherit;
        }

            .pref-toggle-btn.active-veg {
                background: #dcfce7;
                color: #15803d;
            }

            .pref-toggle-btn.active-nonveg {
                background: #fff7ed;
                color: #c2410c;
            }

        .remove-btn {
            width: 20px;
            height: 20px;
            border-radius: 5px;
            border: none;
            background: #fef2f2;
            color: #dc2626;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            flex-shrink: 0;
            transition: all 0.15s;
        }

            .remove-btn:hover {
                background: #fee2e2;
                transform: scale(1.1);
            }

        .empty-state {
            text-align: center;
            padding: 14px 10px;
            color: #a89fd8;
            font-size: 11px;
        }

            .empty-state i {
                font-size: 20px;
                display: block;
                margin-bottom: 5px;
                opacity: 0.4;
            }

        /* ── Submit ── */
        .btn-submit {
            width: 100%;
            padding: 11px;
            background: linear-gradient(135deg, #4a2d9c, #7c3aed);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            font-family: inherit;
        }

            .btn-submit:hover:not(:disabled) {
                transform: translateY(-1px);
                box-shadow: 0 5px 16px rgba(124,58,237,0.35);
            }

            .btn-submit:disabled {
                opacity: 0.45;
                cursor: not-allowed;
            }

        .toast-msg {
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 11px;
            font-weight: 500;
            margin-top: 10px;
            display: none;
            align-items: center;
            gap: 7px;
        }

            .toast-msg.success {
                background: #dcfce7;
                color: #15803d;
                border: 1px solid #bbf7d0;
            }

            .toast-msg.error {
                background: #fef2f2;
                color: #dc2626;
                border: 1px solid #fecaca;
            }

        .cnt-badge {
            margin-left: auto;
            background: #ede9fe;
            color: #5b21b6;
            border-radius: 20px;
            padding: 1px 8px;
            font-size: 10px;
            font-weight: 700;
        }

        @@media (max-width: 1100px) {
            .schedule-wrapper {
                grid-template-columns: 1fr 220px;
            }

            .calendar-card {
                max-width: 100%;
            }
        }

        @@media (max-width: 900px) {
            .schedule-wrapper {
                grid-template-columns: 1fr;
            }

            .calendar-card {
                max-width: 100%;
            }

            .right-panel {
                position: static;
                flex-direction: row;
                flex-wrap: wrap;
            }

            .panel-card {
                flex: 1;
                min-width: 220px;
            }
        }

        @@media (max-width: 500px) {
            .calendar-card {
                padding: 10px;
            }

            .cal-day {
                font-size: 12px;
                border-radius: 6px;
                max-height: 40px;
            }

            .right-panel {
                flex-direction: column;
            }

            .schedule-wrapper {
                gap: 12px;
            }
        }
    </style>
}
<div class="schedule-wrapper">

    <!-- ── LEFT: Calendar ── -->
    <div class="calendar-card">
        <div class="calendar-header">
            <a href="@Url.Action("Schedule", "Lunch", new { month = prevMonth.Month, year = prevMonth.Year })"
               class="nav-btn" title="Previous Month">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <h3>@firstDay.ToString("MMMM yyyy")</h3>
            <a href="@Url.Action("Schedule", "Lunch", new { month = nextMonth.Month, year = nextMonth.Year })"
               class="nav-btn" title="Next Month">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>

        <!-- Day Name Headers -->
        <div class="day-names">
            @foreach (var d in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
            {
                <div class="day-name-label">@d</div>
            }
        </div>

        <!-- Calendar Grid -->
        <div class="calendar-grid">

            @* Empty offset *@
            @for (int i = 0; i < startOffset; i++)
            {
                <div class="cal-day empty"></div>
            }

            @* Day Cells *@
            @for (int d = 1; d <= daysInMonth; d++)
            {
                var date = new DateTime(currentYear, currentMonth, d);
                var dateStr = date.ToString("yyyy-MM-dd");
                var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                var isToday = date.Date == today.Date;
                var isPast = date.Date < today.Date;
                var isTomorrow = date.Date == today.AddDays(1).Date;
                var isCutoff = isTomorrow && DateTime.Now.Hour >= 16;
                var registered = Model.RegisteredDays.FirstOrDefault(r => r.Date == dateStr);
                var isReg = registered != null;
                var holiday = Model.Holidays.FirstOrDefault(h => h.Date == dateStr);
                var isCompany = holiday?.Type == "Company";
                var isOptional = holiday?.Type == "Optional";

                string css;
                bool clickable;

                if (isWeekend) { css = "weekend"; clickable = false; }
                else if (isToday) { css = "today-day"; clickable = false; }
                else if (isPast) { css = "past"; clickable = false; }
                else if (isCutoff) { css = "past"; clickable = false; }
                else if (isCompany) { css = "company-holiday"; clickable = false; }
                else if (isReg) { css = "registered"; clickable = true; }
                else if (isOptional) { css = "optional-holiday"; clickable = true; }
                else { css = "available"; clickable = true; }

                var prefClass = isReg
                ? (registered.Preference == "Veg" ? "veg" : "nonveg")
                : "";

                if (clickable)
                {
                    <div class="cal-day @css"
                         data-date="@dateStr"
                         data-registered="@(isReg ? "true" : "false")"
                         data-preference="@(isReg? registered.Preference: "Veg")"
                         data-optional="@(isOptional ? "true" : "false")"
                         onclick="toggleDay(this)"
                         title="@(holiday != null ? holiday.Name : date.ToString("dd MMM yyyy"))">
                        @d
                        @if (isReg)
                        {
                            <div class="pref-dot @prefClass"></div>
                        }
                    </div>
                }
                else
                {
                    <div class="cal-day @css"
                         title="@(holiday != null ? holiday.Name : date.ToString("dd MMM yyyy"))">
                        @d
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="right-panel">

        <!-- Compact Legend -->
        <div class="panel-card">
            <div class="panel-title">
                <i class="fa-solid fa-circle-info"></i> Legend
            </div>
            <div class="legend-grid">
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#faf9ff;border-color:#ede9fe;"></div>
                    Available
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:linear-gradient(135deg,#4a2d9c,#7c3aed);border-color:#7c3aed;"></div>
                    Selected
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#dcfce7;border-color:#16a34a;"></div>
                    Registered
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:linear-gradient(135deg,#14532d,#16a34a);border-color:#15803d;"></div>
                    Editing
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#fef2f2;border-color:#fecaca;"></div>
                    <span style="color:#dc2626;font-weight:600;">Company</span>
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#fffbeb;border-color:#fde68a;"></div>
                    <span style="color:#d97706;font-weight:600;">Optional</span>
                </div>
                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#f9fafb;border-color:#e5e7eb;"></div>
                    <span style="color:#9ca3af;">Unavailable</span>
                </div>
            </div>
        </div>

        <!-- Selected Days -->
        <div class="panel-card">
            <div class="panel-title">
                <i class="fa-solid fa-calendar-check"></i>
                Selected Days
                <span class="cnt-badge" id="dayCount">0</span>
            </div>
            <div class="selected-list" id="selectedList">
                <div class="empty-state" id="emptyState">
                    <i class="fa-regular fa-calendar-xmark"></i>
                    Click days on calendar to select
                </div>
            </div>
        </div>

        <!-- Submit -->
        <div class="panel-card">
            <button class="btn-submit" id="btnSubmit" disabled onclick="submitRegistration()">
                <i class="fa-solid fa-check"></i> Confirm Registration
            </button>
            <div class="toast-msg" id="toastMsg"></div>
        </div>

    </div>
</div>
@section Scripts {
    <script>
        // ── Data from server ──
        var registeredDays = @Html.Raw(
                    Newtonsoft.Json.JsonConvert.SerializeObject(Model.RegisteredDays)
            );

    // Two separate maps
    var registeredMap = {};  // from server — already registered
    var selectedMap   = {};  // new selections only — sent on submit

        $(document).ready(function () {
            // Load registered days into registeredMap only
            registeredDays.forEach(function (r) {
                registeredMap[r.date] = r.preference;
            });
            updateCount();
        });

        // ── Toggle day on calendar click ──
        function toggleDay(el) {
            var date  = $(el).attr('data-date');
            var isReg = $(el).attr('data-registered') === 'true';
            var pref  = $(el).attr('data-preference') || 'Veg';
            var isOpt = $(el).attr('data-optional') === 'true';

            if (!date) return;

            if (selectedMap.hasOwnProperty(date)) {
                // ── Deselect ──
                delete selectedMap[date];
                removeRow(date);

                if (isReg) {
                    $(el).removeClass('selected registered-selected').addClass('registered');
                    if (!$(el).find('.pref-dot').length) {
                        var prefClass = registeredMap[date] === 'Veg' ? 'veg' : 'nonveg';
                        $(el).append('<div class="pref-dot ' + prefClass + '"></div>');
                    }
                } else {
                    $(el).removeClass('selected').addClass(isOpt ? 'optional-holiday' : 'available');
                }

            } else {
                // ── Select ──
                var initPref = isReg ? registeredMap[date] : 'Veg';
                selectedMap[date] = initPref;

                // ✅ Pass isReg to renderRow so it knows which button to show
                renderRow(date, initPref, isReg);

                if (isReg) {
                    $(el).removeClass('registered').addClass('registered-selected');
                } else {
                    $(el).removeClass('available optional-holiday').addClass('selected');
                }
            }

            updateCount();
        }

        // ── Render a row in the right panel ──
        // ✅ isReg flag determines if row shows Delete or just Remove
        function renderRow(date, preference, isReg) {
            var dt    = new Date(date + 'T00:00:00');
            var label = dt.toLocaleDateString('en-IN', {
                weekday: 'short', day: '2-digit', month: 'short'
            });
            var isVeg = preference === 'Veg';

            // ✅ If already registered → show delete button (red trash)
            // ✅ If new selection → show remove button (grey x)
            var actionBtn = isReg
                ? '<button class="delete-btn" onclick="confirmDelete(\'' + date + '\', \'' + label + '\')" title="Cancel this registration">' +
                      '<i class="fa-solid fa-trash-can"></i>' +
                  '</button>'
                : '<button class="remove-btn" onclick="removeDay(\'' + date + '\')">' +
                      '<i class="fa-solid fa-xmark"></i>' +
                  '</button>';

            // ✅ If registered → show edit badge
            var badge = isReg
                ? '<span class="edit-badge">Editing</span>'
                : '<span class="new-badge">New</span>';

            var row = $(
                '<div class="selected-row" id="row-' + date + '">' +
                    '<div style="display:flex;flex-direction:column;flex:1;min-width:0;">' +
                        '<span class="selected-date-label">📅 ' + label + '</span>' +
                        
                    '</div>' +
                    '<div class="pref-toggle">' +
                        '<button class="pref-toggle-btn ' + (isVeg ? 'active-veg' : '') + '" ' +
                                'onclick="setPref(\'' + date + '\', \'Veg\', this)">🥦 Veg</button>' +
                        '<button class="pref-toggle-btn ' + (!isVeg ? 'active-nonveg' : '') + '" ' +
                                'onclick="setPref(\'' + date + '\', \'NonVeg\', this)">🍗 NV</button>' +
                    '</div>' +
                    actionBtn +
                '</div>'
            );

            $('#emptyState').hide();
            $('#selectedList').append(row);
        }

        // ── Remove row from panel (UI only) ──
        function removeRow(date) {
            $('#row-' + date).remove();
            if (Object.keys(selectedMap).length === 0) {
                $('#emptyState').show();
            }
        }

        // ── Remove NEW selection via x button ──
        function removeDay(date) {
            var calCell = $('[data-date="' + date + '"]');
            var isReg   = calCell.attr('data-registered') === 'true';
            var isOpt   = calCell.attr('data-optional') === 'true';

            delete selectedMap[date];
            removeRow(date);

            if (isReg) {
                calCell.removeClass('registered-selected').addClass('registered');
                if (!calCell.find('.pref-dot').length) {
                    var prefClass = registeredMap[date] === 'Veg' ? 'veg' : 'nonveg';
                    calCell.append('<div class="pref-dot ' + prefClass + '"></div>');
                }
            } else {
                calCell.removeClass('selected').addClass(isOpt ? 'optional-holiday' : 'available');
            }

            updateCount();
        }

        // ── Confirm Delete popup ──
        function confirmDelete(date, label) {
            // ✅ Show inline confirm inside the row instead of browser alert
            var row = $('#row-' + date);

            // Prevent duplicate confirm
            if (row.find('.confirm-box').length) return;

            var confirmBox = $(
                '<div class="confirm-box">' +
                    '<span>Cancel lunch for <strong>' + label + '</strong>?</span>' +
                        '<div style="display:flex;gap:6px;margin-top:8px;justify-content: center;">' +
                        '<button class="confirm-yes" onclick="deleteRegistration(\'' + date + '\')">Yes, Cancel</button>' +
                        '<button class="confirm-no" onclick="closeConfirm(\'' + date + '\')">No</button>' +
                    '</div>' +
                '</div>'
            );

            row.append(confirmBox);
        }

        // ── Close confirm box ──
        function closeConfirm(date) {
            $('#row-' + date + ' .confirm-box').remove();
        }

        // ── Delete registration from DB via Ajax ──
        function deleteRegistration(date) {
            var calCell = $('[data-date="' + date + '"]');

            // Disable row buttons during request
            $('#row-' + date).find('button').prop('disabled', true);
            $('#row-' + date + ' .confirm-box span').html(
                '<i class="fa-solid fa-spinner fa-spin"></i> Cancelling...'
            );

            $.ajax({
                url: '@Url.Action("Remove", "Lunch")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ date: date }),
                success: function (res) {
                    if (res.success) {
                        // ✅ Remove from registeredMap
                        delete registeredMap[date];
                        delete selectedMap[date];

                        // ✅ Remove row from panel
                        $('#row-' + date).fadeOut(300, function () {
                            $(this).remove();
                            if (Object.keys(selectedMap).length === 0) {
                                $('#emptyState').show();
                            }
                        });

                        // ✅ Reset calendar cell to available
                        calCell.removeClass('registered registered-selected')
                               .addClass('available')
                               .attr('data-registered', 'false')
                               .attr('data-preference', 'Veg')
                               .find('.pref-dot').remove();

                        showToast(true, res.message);
                        updateCount();

                    } else {
                        showToast(false, res.message);
                        $('#row-' + date).find('button').prop('disabled', false);
                        closeConfirm(date);
                    }
                },
                error: function () {
                    showToast(false, 'Something went wrong. Please try again.');
                    $('#row-' + date).find('button').prop('disabled', false);
                    closeConfirm(date);
                }
            });
        }

        // ── Set preference per day ──
        function setPref(date, pref, btn) {
            selectedMap[date] = pref;
            var toggle = $(btn).closest('.pref-toggle');
            toggle.find('.pref-toggle-btn').removeClass('active-veg active-nonveg');
            $(btn).addClass(pref === 'Veg' ? 'active-veg' : 'active-nonveg');
        }

        // ── Update count badge ──
        function updateCount() {
            var count = Object.keys(selectedMap).length;
            $('#dayCount').text(count);
            $('#btnSubmit').prop('disabled', count === 0);
        }

        // ── Submit new/modified registrations ──
        function submitRegistration() {
            var days = Object.keys(selectedMap).map(function (date) {
                return { date: date, preference: selectedMap[date] };
            });

            if (days.length === 0) return;

            $('#btnSubmit').prop('disabled', true)
                           .html('<i class="fa-solid fa-spinner fa-spin"></i> Saving...');

            $.ajax({
                url: '@Url.Action("Save", "Lunch")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ days: days }),
                success: function (res) {
                    showToast(res.success, res.message);
                    if (res.success) {
                        setTimeout(function () { location.reload(); }, 1800);
                    } else {
                        resetBtn();
                    }
                },
                error: function () {
                    showToast(false, 'Something went wrong. Please try again.');
                    resetBtn();
                }
            });
        }

        // ── Show Toast ──
        function showToast(success, message) {
            var el = $('#toastMsg');
            el.removeClass('success error')
              .addClass(success ? 'success' : 'error')
              .html('<i class="fa-solid fa-' + (success ? 'circle-check' : 'circle-exclamation') + '"></i> ' + message)
              .css('display', 'flex');

            if (!success) {
                setTimeout(function () { el.fadeOut(); }, 4000);
            }
        }

        // ── Reset Submit Button ──
        function resetBtn() {
            $('#btnSubmit').prop('disabled', false)
                           .html('<i class="fa-solid fa-check"></i> Confirm Registration');
        }
    </script>
}
