        }

        @@media (max-width:900px) {
            .schedule-wrapper {
                grid-template-columns: 1fr;
            }

            .calendar-card {
                max-width: 100%;
            }

            .right-panel {
                position: static;
                flex-direction: row;
                flex-wrap: wrap;
            }

            .panel-card {
                flex: 1;
                min-width: 220px;
            }
        }

        @@media (max-width:500px) {
            .calendar-card {
                padding: 10px;
            }

            .cal-day {
                font-size: 12px;
                border-radius: 6px;
                max-height: 40px;
            }

            .right-panel {
                flex-direction: column;
            }

            .schedule-wrapper {
                gap: 12px;
            }

            .lunch-banner {
                flex-direction: column;
                align-items: flex-start;
            }

            .banner-countdown {
                font-size: 16px;
            }
        }
    </style>
}

@* ══════════════════════════════════════════════
   SCENARIO 1 — Already registered for next working day
   ══════════════════════════════════════════════ *@
@if (isNextDayRegistered)
{
    <div class="lunch-banner success">
        <div class="banner-left">
            <div class="banner-icon"><i class="fa-solid fa-circle-check"></i></div>
            <div class="banner-text">
                <div class="title">
                    @if (isTomorrowNextWorkingDay)
                    {
                        <span>You're registered for tomorrow (@nextWorkingDay.ToString("dddd, dd MMM"))! ✅</span>
                    }
                    else
                    {
                        <span>You're registered for @nextWorkingDay.ToString("dddd, dd MMM")! ✅</span>
                    }
                </div>
                <div class="subtitle">
                    @if (!isPastCutoff && isTomorrowNextWorkingDay)
                    {
                        <span>You can still modify your preference before 4:00 PM today</span>
                    }
                    else if (!isPastCutoff && isTomorrowWeekendOrHoliday)
                    {
                        <span>
                            <span style="color:#b91c1c">
                            Tomorrow is a weekend/holiday 
                            </span>🎉 —
                            next working day: <strong>@nextWorkingDay.ToString("dddd, dd MMM")</strong>
                        </span>
                    }
                    else
                    {
                        <span>
                            <span style="color:#b91c1c">Today's registration window is closed ❌</span>
                            — you can still register from <strong>@nextAvailableDay.ToString("dddd, dd MMM")</strong> onwards
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════
   SCENARIO 2 — Tomorrow is weekend or company holiday
   ══════════════════════════════════════════════ *@
else if (isTomorrowWeekendOrHoliday)
{
    <div class="lunch-banner info" id="lunchBanner">
        <div class="banner-left">
            <div class="banner-icon"><i class="fa-solid fa-calendar-week"></i></div>
            <div class="banner-text">
                <div class="title">
                    Tomorrow is a
                    @(tomorrow.DayOfWeek == DayOfWeek.Saturday || tomorrow.DayOfWeek == DayOfWeek.Sunday
                                    ? "weekend 🎉" : "company holiday 🎉")
                </div>
                <div class="subtitle">
                    Next working day is <strong>@nextWorkingDay.ToString("dddd, dd MMM yyyy")</strong> — register your lunch for that day!
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════
   SCENARIO 3 — Before 4 PM, tomorrow is a working day
   ══════════════════════════════════════════════ *@
else if (!isPastCutoff)
{
    <div class="lunch-banner warning" id="lunchBanner">
        <div class="banner-left">
            <div class="banner-icon"><i class="fa-solid fa-clock"></i></div>
            <div class="banner-text">
                <div class="title">Register for tomorrow's lunch before 4:00 PM!</div>
                <div class="subtitle">
                    Tomorrow is <strong>@nextWorkingDay.ToString("dddd, dd MMM yyyy")</strong> — don't miss out!
                </div>
            </div>
        </div>
        <div class="banner-countdown" id="countdownTimer">
            @hoursLeft hr @minsLeft min left
        </div>
    </div>
}

@* ══════════════════════════════════════════════
   SCENARIO 4 — Past 4 PM, window closed
   ══════════════════════════════════════════════ *@
else
{
    <div class="lunch-banner danger">
        <div class="banner-left">
            <div class="banner-icon"><i class="fa-solid fa-circle-xmark"></i></div>
            <div class="banner-text">
                <div class="title">Today's registration window is now closed ❌</div>
                <div class="subtitle">
                    You can still register from <strong>@nextAvailableDay.ToString("dddd, dd MMM")</strong> onwards
                </div>
            </div>
        </div>
    </div>
}

<div class="schedule-wrapper">

    <div class="calendar-card">
        <div class="calendar-header">
            <a href="@Url.Action("Schedule", "Lunch", new { month = prevMonth.Month, year = prevMonth.Year })" class="nav-btn" title="Previous Month">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <h3>@firstDay.ToString("MMMM yyyy")</h3>
            <a href="@Url.Action("Schedule", "Lunch", new { month = nextMonth.Month, year = nextMonth.Year })" class="nav-btn" title="Next Month">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>
        <div class="day-names">
            @foreach (var d in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
            {
                <div class="day-name-label">@d</div>
            }
        </div>
        <div class="calendar-grid">
            @for (int i = 0; i < startOffset; i++)
            {
                <div class="cal-day empty"></div>
            }
            @for (int d = 1; d <= daysInMonth; d++)
            {
                var date = new DateTime(currentYear, currentMonth, d);
                var dateStr = date.ToString("yyyy-MM-dd");
                var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                var isToday = date.Date == today.Date;
                var isPast = date.Date < today.Date;
                var isTomorrowD = date.Date == today.AddDays(1).Date;
                var isCutoff = isTomorrowD && DateTime.Now.Hour >= 16;
                var registered = Model.RegisteredDays.FirstOrDefault(r => r.Date == dateStr);
                var isReg = registered != null;
                var holiday = Model.Holidays.FirstOrDefault(h => DateTime.Parse(h.Date).Date == date.Date);
                var isCompany = holiday?.Type == "Company";
                var isOptional = holiday?.Type == "Optional";

                string css; bool clickable;
                if (isWeekend) { css = "weekend"; clickable = false; }
                else if (isToday) { css = "today-day"; clickable = false; }
                else if (isPast) { css = "past"; clickable = false; }
                else if (isCutoff) { css = "past"; clickable = false; }
                else if (isCompany) { css = "company-holiday"; clickable = false; }
                else if (isReg) { css = "registered"; clickable = true; }
                else if (isOptional) { css = "optional-holiday"; clickable = true; }
                else { css = "available"; clickable = true; }

                var prefClass = isReg ? (registered?.Preference == "Veg" ? "veg" : "nonveg") : "";

                if (clickable)
                {
                    <div class="cal-day @css"
                         data-date="@dateStr"
                         data-registered="@(isReg ? "true" : "false")"
                         data-preference="@(isReg? registered?.Preference : "Veg")"
                         data-optional="@(isOptional ? "true" : "false")"
                         onclick="toggleDay(this)"
                         title="@(holiday != null ? holiday.Name : date.ToString("dd MMM yyyy"))">
                        @d
                        @if (isReg)
                        {
                            <div class="pref-dot @prefClass"></div>
                        }
                    </div>
                }
                else
                {
                    <div class="cal-day @css" title="@(holiday != null ? holiday.Name : date.ToString("dd MMM yyyy"))">@d</div>
                }
            }
        </div>
    </div>

    <div class="right-panel">
        <div class="panel-card">
            <div class="panel-title"><i class="fa-solid fa-circle-info"></i> Legend</div>
            <div class="legend-grid">
                <div class="legend-item"><div class="legend-box" style="background:#faf9ff;border-color:#ede9fe;"></div> Available</div>
                <div class="legend-item"><div class="legend-box" style="background:linear-gradient(135deg,#4a2d9c,#7c3aed);border-color:#7c3aed;"></div> Selected</div>
                <div class="legend-item"><div style="width:10px;height:10px;border-radius:50%;background:#16a34a;flex-shrink:0;"></div><span style="color:#15803d;font-weight:600;">Veg</span></div>
                <div class="legend-item"><div class="legend-box" style="background:linear-gradient(135deg,#14532d,#16a34a);border-color:#15803d;"></div> Editing</div>
                <div class="legend-item"><div class="legend-box" style="background:#fef2f2;border-color:#fecaca;"></div><span style="color:#dc2626;font-weight:600;">Company</span></div>
                <div class="legend-item"><div style="width:10px;height:10px;border-radius:50%;background:#ea580c;flex-shrink:0;"></div><span style="color:#c2410c;font-weight:600;">Non-Veg</span></div>
                <div class="legend-item"><div class="legend-box" style="background:#fffbeb;border-color:#fde68a;"></div><span style="color:#d97706;font-weight:600;">Optional</span></div>
                <div class="legend-item"><div class="legend-box" style="background:#dcfce7;border-color:#16a34a;"></div> Registered</div>
            </div>
        </div>
        <div class="panel-card">
            <div class="panel-title">
                <i class="fa-solid fa-calendar-check"></i> Selected Days
                <span class="cnt-badge" id="dayCount">0</span>
            </div>
            <div class="selected-list" id="selectedList">
                <div class="empty-state" id="emptyState">
                    <i class="fa-regular fa-calendar-xmark"></i>
                    Click days on calendar to select
                </div>
            </div>
        </div>
        <div class="panel-card">
            <button class="btn-submit" id="btnSubmit" disabled onclick="submitRegistration()">
                <i class="fa-solid fa-check"></i> Confirm Registration
            </button>
            <div class="toast-msg" id="toastMsg"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var registeredDays = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RegisteredDays));
        var registeredMap  = {};
        var selectedMap    = {};

        $(document).ready(function () {
            registeredDays.forEach(function (r) { registeredMap[r.date] = r.preference; });
            updateCount();
            startCountdown();
        });

        function startCountdown() {
            var banner = $('#lunchBanner');
            if (banner.length === 0) return;
            function tick() {
                var now = new Date(), cutoff = new Date();
                cutoff.setHours(16, 0, 0, 0);
                var diff = cutoff - now;
                if (diff <= 0) {
                    banner.replaceWith(
                        '<div class="lunch-banner danger">' +
                            '<div class="banner-left">' +
                                '<div class="banner-icon"><i class="fa-solid fa-circle-xmark"></i></div>' +
                                '<div class="banner-text">' +
                                    '<div class="title">Today\'s registration window is now closed &#10060;</div>' +
                                    '<div class="subtitle">You can still register for future dates</div>' +
                                '</div>' +
                            '</div>' +
                        '</div>'
                    );
                    return;
                }
                var h = Math.floor(diff / 3600000);
                var m = Math.floor((diff % 3600000) / 60000);
                var s = Math.floor((diff % 60000) / 1000);
                $('#countdownTimer').text(h + ' hr ' + m + ' min ' + s + ' sec left');
                setTimeout(tick, 1000);
            }
            tick();
        }

        function toggleDay(el) {
            var date  = $(el).attr('data-date');
            var isReg = $(el).attr('data-registered') === 'true';
            var isOpt = $(el).attr('data-optional') === 'true';
            if (!date) return;
            if (selectedMap.hasOwnProperty(date)) {
                delete selectedMap[date];
                removeRow(date);
                if (isReg) {
                    $(el).removeClass('selected registered-selected').addClass('registered');
                    if (!$(el).find('.pref-dot').length) {
                        var pc = registeredMap[date] === 'Veg' ? 'veg' : 'nonveg';
                        $(el).append('<div class="pref-dot ' + pc + '"></div>');
                    }
                } else {
                    $(el).removeClass('selected').addClass(isOpt ? 'optional-holiday' : 'available');
                }
            } else {
                var initPref = isReg ? registeredMap[date] : 'Veg';
                selectedMap[date] = initPref;
                renderRow(date, initPref, isReg);
                if (isReg) { $(el).removeClass('registered').addClass('registered-selected'); }
                else       { $(el).removeClass('available optional-holiday').addClass('selected'); }
            }
            updateCount();
        }

        function renderRow(date, preference, isReg) {
            var dt    = new Date(date + 'T00:00:00');
            var label = dt.toLocaleDateString('en-IN', { weekday:'short', day:'2-digit', month:'short' });
            var isVeg = preference === 'Veg';
            var actionBtn = isReg
                ? '<button class="delete-btn" onclick="confirmDelete(\'' + date + '\',\'' + label + '\')" title="Cancel"><i class="fa-solid fa-trash-can"></i></button>'
                : '<button class="remove-btn" onclick="removeDay(\'' + date + '\')"><i class="fa-solid fa-xmark"></i></button>';
            var row = $(
                '<div class="selected-row" id="row-' + date + '">' +
                    '<span class="selected-date-label">&#128197; ' + label + '</span>' +
                    '<div class="pref-toggle">' +
                        '<button class="pref-toggle-btn ' + (isVeg ? 'active-veg' : '') + '" onclick="setPref(\'' + date + '\',\'Veg\',this)">&#129382; Veg</button>' +
                        '<button class="pref-toggle-btn ' + (!isVeg ? 'active-nonveg' : '') + '" onclick="setPref(\'' + date + '\',\'NonVeg\',this)">&#127831; NV</button>' +
                    '</div>' +
                    actionBtn +
                '</div>'
            );
            $('#emptyState').hide();
            $('#selectedList').append(row);
        }

        function removeRow(date) {
            $('#row-' + date).remove();
            if (Object.keys(selectedMap).length === 0) $('#emptyState').show();
        }

        function removeDay(date) {
            var calCell = $('[data-date="' + date + '"]');
            var isReg   = calCell.attr('data-registered') === 'true';
            var isOpt   = calCell.attr('data-optional') === 'true';
            delete selectedMap[date];
            removeRow(date);
            if (isReg) {
                calCell.removeClass('registered-selected').addClass('registered');
                if (!calCell.find('.pref-dot').length) {
                    var pc = registeredMap[date] === 'Veg' ? 'veg' : 'nonveg';
                    calCell.append('<div class="pref-dot ' + pc + '"></div>');
                }
            } else {
                calCell.removeClass('selected').addClass(isOpt ? 'optional-holiday' : 'available');
            }
            updateCount();
        }

        function confirmDelete(date, label) {
            var row = $('#row-' + date);
            if (row.next('.confirm-box').length) return;
            var box = $(
                '<div class="confirm-box">' +
                    '<span>Cancel lunch for <strong>' + label + '</strong>?</span>' +
                    '<div style="display:flex;gap:6px;margin-top:8px;justify-content:center;">' +
                        '<button class="confirm-yes" onclick="deleteRegistration(\'' + date + '\')">Yes, Cancel</button>' +
                        '<button class="confirm-no" onclick="closeConfirm(\'' + date + '\')">No</button>' +
                    '</div>' +
                '</div>'
            );
            row.after(box);
        }

        function closeConfirm(date) { $('#row-' + date).next('.confirm-box').remove(); }

        function updateBannerAfterDelete(deletedDate) {
            var nextWorkingDay            = '@nextWorkingDay.ToString("yyyy-MM-dd")';
            var nextWorkingDayFormatted   = '@nextWorkingDay.ToString("dddd, dd MMM yyyy")';
            var nextAvailableDayFormatted = '@nextAvailableDay.ToString("dddd, dd MMM")';
            if (deletedDate !== nextWorkingDay) return;

            var now = new Date(), cutoff = new Date();
            cutoff.setHours(16, 0, 0, 0);
            var isPastCutoff               = now >= cutoff;
            var isTomorrowWeekendOrHoliday = @isTomorrowWeekendOrHoliday.ToString().ToLower();

            var html = '';
            if (isTomorrowWeekendOrHoliday) {
                html =
                    '<div class="lunch-banner info" id="lunchBanner">' +
                        '<div class="banner-left">' +
                            '<div class="banner-icon"><i class="fa-solid fa-calendar-week"></i></div>' +
                            '<div class="banner-text">' +
                                '<div class="title">Tomorrow is a weekend/holiday &#127881;</div>' +
                                '<div class="subtitle">Next working day is <strong>' + nextWorkingDayFormatted + '</strong> &#8212; register your lunch for that day!</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            } else if (!isPastCutoff) {
                var h = Math.floor((cutoff - now) / 3600000);
                var m = Math.floor(((cutoff - now) % 3600000) / 60000);
                var s = Math.floor(((cutoff - now) % 60000) / 1000);
                html =
                    '<div class="lunch-banner warning" id="lunchBanner">' +
                        '<div class="banner-left">' +
                            '<div class="banner-icon"><i class="fa-solid fa-clock"></i></div>' +
                            '<div class="banner-text">' +
                                '<div class="title">Register for tomorrow\'s lunch before 4:00 PM!</div>' +
                                '<div class="subtitle">Tomorrow is <strong>' + nextWorkingDayFormatted + '</strong> &#8212; don\'t miss out!</div>' +
                            '</div>' +
                        '</div>' +
                        '<div class="banner-countdown" id="countdownTimer">' + h + ' hr ' + m + ' min ' + s + ' sec left</div>' +
                    '</div>';
            } else {
                html =
                    '<div class="lunch-banner danger">' +
                        '<div class="banner-left">' +
                            '<div class="banner-icon"><i class="fa-solid fa-circle-xmark"></i></div>' +
                            '<div class="banner-text">' +
                                '<div class="title">Today\'s registration window is now closed &#10060;</div>' +
                                '<div class="subtitle">You can still register from <strong>' + nextAvailableDayFormatted + '</strong> onwards</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            $('.lunch-banner').replaceWith(html);
            if (!isPastCutoff && !isTomorrowWeekendOrHoliday) startCountdown();
        }

        function deleteRegistration(date) {
            var calCell    = $('[data-date="' + date + '"]');
            var confirmBox = $('#row-' + date).next('.confirm-box');
            confirmBox.find('button').prop('disabled', true);
            confirmBox.find('span').html('<i class="fa-solid fa-spinner fa-spin"></i> Cancelling...');
            $.ajax({
                url: '@Url.Action("Remove", "Lunch")',
                type: 'POST', contentType: 'application/json',
                data: JSON.stringify({ date: date }),
                success: function (res) {
                    if (res.success) {
                        delete registeredMap[date]; delete selectedMap[date];
                        confirmBox.remove();
                        $('#row-' + date).fadeOut(300, function () {
                            $(this).remove();
                            if (Object.keys(selectedMap).length === 0) $('#emptyState').show();
                        });
                        calCell.removeClass('registered registered-selected')
                               .addClass('available')
                               .attr('data-registered', 'false')
                               .attr('data-preference', 'Veg')
                               .find('.pref-dot').remove();
                        showToast(true, res.message);
                        updateCount();
                        updateBannerAfterDelete(date);
                    } else {
                        showToast(false, res.message);
                        confirmBox.find('button').prop('disabled', false);
                        closeConfirm(date);
                    }
                },
                error: function () {
                    showToast(false, 'Something went wrong. Please try again.');
                    confirmBox.find('button').prop('disabled', false);
                    closeConfirm(date);
                }
            });
        }

        function setPref(date, pref, btn) {
            selectedMap[date] = pref;
            $(btn).closest('.pref-toggle').find('.pref-toggle-btn').removeClass('active-veg active-nonveg');
            $(btn).addClass(pref === 'Veg' ? 'active-veg' : 'active-nonveg');
        }

        function updateCount() {
            var count = Object.keys(selectedMap).length;
            $('#dayCount').text(count);
            $('#btnSubmit').prop('disabled', count === 0);
        }

        function submitRegistration() {
            var days = Object.keys(selectedMap).map(function (date) {
                return { date: date, preference: selectedMap[date] };
            });
            if (days.length === 0) return;
            $('#btnSubmit').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Saving...');
            $.ajax({
                url: '@Url.Action("Save", "Lunch")',
                type: 'POST', contentType: 'application/json',
                data: JSON.stringify({ days: days }),
                success: function (res) {
                    showToast(res.success, res.message);
                    if (res.success) { setTimeout(function () { location.reload(); }, 1800); }
                    else             { resetBtn(); }
                },
                error: function () { showToast(false, 'Something went wrong. Please try again.'); resetBtn(); }
            });
        }

        function showToast(success, message) {
            var el = $('#toastMsg');
            el.removeClass('success error')
              .addClass(success ? 'success' : 'error')
              .html('<i class="fa-solid fa-' + (success ? 'circle-check' : 'circle-exclamation') + '"></i> ' + message)
              .css('display', 'flex');
            if (!success) setTimeout(function () { el.fadeOut(); }, 4000);
        }

        function resetBtn() {
            $('#btnSubmit').prop('disabled', false).html('<i class="fa-solid fa-check"></i> Confirm Registration');
        }
    </script>
}
