<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MealLedger</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sidebar-collapsed: 64px;
            --sidebar-expanded: 220px;
            --bg: #f4f3ff;
            --white: #ffffff;
            --purple: #5b21b6;
            --purple-mid: #7c3aed;
            --purple-light: #ede9fe;
            --purple-dark: #2d1b69;
            --navy: #1e1b4b;
            --text-dark: #1e1b4b;
            --text-mid: #5b5b8a;
            --text-light: #a89fd8;
            --border: #e5e0f8;
            --shadow: 0 4px 24px rgba(91,33,182,0.08);
            --radius: 14px;
            --transition: 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ══ SIDEBAR ══ */
        .sidebar {
            width: var(--sidebar-collapsed);
            min-height: 100vh;
            background: linear-gradient(180deg, #2d1b69 0%, #4a2d9c 50%, #5b21b6 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 0 24px;
            gap: 4px;
            box-shadow: 2px 0 16px rgba(45,27,105,0.18);
            transition: width var(--transition);
            overflow: hidden;
            flex-shrink: 0;
            z-index: 200;
            position: relative;
        }

            .sidebar:hover {
                width: var(--sidebar-expanded);
                align-items: stretch;
            }

        /* Logo */
        .sidebar-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 0 14px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 10px;
            min-height: 48px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 17px;
            flex-shrink: 0;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .logo-text {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            white-space: nowrap;
            overflow: hidden;
            max-width: 0;
            opacity: 0;
            transition: max-width var(--transition), opacity var(--transition), margin var(--transition);
        }

        .sidebar:hover .logo-text {
            max-width: 140px;
            opacity: 1;
            margin-left: 10px;
        }

        /* Nav */
        .nav-section {
            width: 100%;
            display: flex;
            flex-direction: column;
            padding: 0 10px;
            gap: 2px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            transition: background var(--transition), color var(--transition);
            white-space: nowrap;
            min-height: 42px;
        }

            .nav-item:hover {
                background: rgba(255,255,255,0.12);
                color: #ffffff;
                text-decoration: none;
            }

            .nav-item.active {
                background: rgba(255,255,255,0.2);
                color: #ffffff;
                border-left: 3px solid #c4b5fd;
            }

        .nav-icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .nav-label {
            font-size: 13.5px;
            font-weight: 500;
            margin-left: 10px;
            overflow: hidden;
            max-width: 0;
            opacity: 0;
            transition: max-width var(--transition), opacity var(--transition);
        }

        .sidebar:hover .nav-label {
            max-width: 160px;
            opacity: 1;
        }

        .nav-divider {
            width: calc(100% - 20px);
            height: 1px;
            background: rgba(255,255,255,0.1);
            margin: 8px 10px;
        }

        /* Bottom avatar + logout */
        .sidebar-bottom {
            margin-top: auto;
            width: 100%;
            padding: 0 10px;
        }

        .avatar-item {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            border-radius: 10px;
        }

        .avatar-circle {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #c4b5fd, #8b5cf6);
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            font-weight: 700;
        }

        .avatar-info {
            margin-left: 10px;
            overflow: hidden;
            max-width: 0;
            opacity: 0;
            transition: max-width var(--transition), opacity var(--transition);
        }

        .sidebar:hover .avatar-info {
            max-width: 140px;
            opacity: 1;
        }

        .avatar-name {
            font-size: 12px;
            font-weight: 600;
            color: #ffffff;
            white-space: nowrap;
        }

        .avatar-role {
            font-size: 11px;
            color: rgba(255,255,255,0.5);
            white-space: nowrap;
        }

        .logout-item {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            transition: background var(--transition), color var(--transition);
            white-space: nowrap;
            min-height: 42px;
            margin-top: 4px;
        }

            .logout-item:hover {
                background: rgba(239,68,68,0.2);
                color: #fca5a5;
                text-decoration: none;
            }

        /* ══ MOBILE OVERLAY + DRAWER ══ */
        .mobile-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.38);
            z-index: 300;
            opacity: 0;
            transition: opacity 0.25s;
            pointer-events: none;
        }

            .mobile-overlay.open {
                opacity: 1;
                pointer-events: all;
            }

        .mobile-drawer {
            position: fixed;
            top: 0;
            left: -260px;
            bottom: 0;
            width: 240px;
            background: linear-gradient(180deg, #2d1b69 0%, #4a2d9c 50%, #5b21b6 100%);
            z-index: 400;
            display: flex;
            flex-direction: column;
            padding: 20px 0 24px;
            gap: 6px;
            box-shadow: 4px 0 20px rgba(45,27,105,0.3);
            transition: left var(--transition);
        }

            .mobile-drawer.open {
                left: 0;
            }

        .drawer-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 16px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 8px;
        }

        .drawer-logo-text {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
        }

        .mobile-drawer .nav-section {
            padding: 0 10px;
        }

        .mobile-drawer .nav-label {
            max-width: 160px;
            opacity: 1;
        }

        .mobile-drawer .nav-item {
            min-height: 46px;
        }

        .mobile-drawer .sidebar-bottom {
            margin-top: auto;
            padding: 0 10px;
        }

        .mobile-drawer .avatar-info {
            max-width: 140px;
            opacity: 1;
        }

        .drawer-close {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255,255,255,0.1);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.7);
            font-size: 14px;
        }

            .drawer-close:hover {
                background: rgba(255,255,255,0.2);
                color: white;
            }

        /* ══ MAIN ══ */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-width: 0;
        }

        .topbar {
            background: var(--white);
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
            box-shadow: 0 1px 6px rgba(91,33,182,0.06);
            flex-shrink: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .topbar-left h1 {
                font-size: 20px;
                font-weight: 700;
                color: var(--navy);
            }

            .topbar-left p {
                font-size: 12.5px;
                color: var(--text-light);
                margin-top: 1px;
            }

        .hamburger {
            display: none;
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: var(--bg);
            border: 1px solid var(--border);
            cursor: pointer;
            align-items: center;
            justify-content: center;
            color: var(--text-mid);
            font-size: 15px;
            flex-shrink: 0;
        }

            .hamburger:hover {
                background: var(--purple-light);
                color: var(--purple-mid);
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-name {
            text-align: right;
        }

            .topbar-name .name {
                font-size: 13px;
                font-weight: 600;
                color: var(--navy);
            }

            .topbar-name .role {
                font-size: 11px;
                color: var(--text-light);
            }

        .topbar-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #c4b5fd, #7c3aed);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 13px;
            flex-shrink: 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            border-radius: 9px;
            font-family: inherit;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid var(--border);
            background: var(--white);
            color: var(--text-mid);
            transition: all 0.2s;
            text-decoration: none;
        }

            .btn-logout:hover {
                background: #fef2f2;
                border-color: #fecaca;
                color: #dc2626;
                text-decoration: none;
            }

        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
        }

        /* ══ MOBILE BOTTOM NAV ══ */
        .bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--border);
            box-shadow: 0 -4px 16px rgba(91,33,182,0.08);
            z-index: 200;
            padding: 8px 0 calc(8px + env(safe-area-inset-bottom));
        }

        .bottom-nav-inner {
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        .bottom-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            padding: 6px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: var(--text-light);
            text-decoration: none;
            transition: color 0.2s;
            min-width: 52px;
        }

            .bottom-nav-item i {
                font-size: 18px;
            }

            .bottom-nav-item span {
                font-size: 10px;
                font-weight: 600;
            }

            .bottom-nav-item.active {
                color: var(--purple-mid);
            }

            .bottom-nav-item:hover {
                color: var(--purple-mid);
            }

        /* scrollbar */
        .page-content::-webkit-scrollbar {
            width: 6px;
        }

        .page-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .page-content::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        /* ══ RESPONSIVE ══ */
        @@media (max-width: 767px) {
            body {
                overflow: auto;
                flex-direction: column;
            }

            .sidebar {
                display: none;
            }

            .hamburger {
                display: flex;
            }

            .mobile-overlay {
                display: block;
            }

            .topbar {
                padding: 12px 16px;
            }

            .topbar-left h1 {
                font-size: 17px;
            }

            .topbar-left p {
                display: none;
            }

            .topbar-name {
                display: none;
            }

            .page-content {
                padding: 16px 14px;
                padding-bottom: 88px;
                overflow-y: auto;
            }

            .bottom-nav {
                display: block;
            }

            .main {
                overflow: auto;
            }
        }

        @@media (max-width: 360px) {
            .topbar-left h1 {
                font-size: 15px;
            }

            .bottom-nav-item span {
                display: none;
            }

            .bottom-nav-item i {
                font-size: 21px;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

    @{
        var fullName = Context.Session.GetString("FullName") ?? "User";
        var role = Context.Session.GetString("Role") ?? "Employee";
        var initials = string.Concat(fullName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
        var isAdmin = role == "Admin";
        var activePage = ViewData["ActivePage"]?.ToString();
    }

    <!-- Mobile Overlay -->
    <div class="mobile-overlay" id="overlay" onclick="closeDrawer()"></div>

    <!-- Mobile Drawer -->
    <div class="mobile-drawer" id="drawer">
        <button class="drawer-close" onclick="closeDrawer()"><i class="fa-solid fa-xmark"></i></button>
        <div class="drawer-logo">
            <div class="logo-icon"><i class="fa-solid fa-utensils"></i></div>
            <span class="drawer-logo-text">MealLedger</span>
        </div>
        <nav class="nav-section">
            <a href="@Url.Action("Index", "Dashboard")"
               class="nav-item @(activePage == "Dashboard" ? "active" : "")"
               onclick="closeDrawer()">
                <i class="nav-icon fa-solid fa-house"></i>
                <span class="nav-label">Dashboard</span>
            </a>
            <a href="@Url.Action("Schedule", "Lunch")"
               class="nav-item @(activePage == "Lunch" ? "active" : "")"
               onclick="closeDrawer()">
                <i class="nav-icon fa-solid fa-utensils"></i>
                <span class="nav-label">Lunch</span>
            </a>
            <a href="@Url.Action("Index", "Calendar")"
               class="nav-item @(activePage == "Calendar" ? "active" : "")"
               onclick="closeDrawer()">
                <i class="nav-icon fa-regular fa-calendar"></i>
                <span class="nav-label">Calendar</span>
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Index", "Admin")"
                   class="nav-item @(activePage == "Admin" ? "active" : "")"
                   onclick="closeDrawer()">
                    <i class="nav-icon fa-solid fa-shield-halved"></i>
                    <span class="nav-label">Admin</span>
                </a>
            }
        </nav>
        <div class="sidebar-bottom">
            <div class="nav-divider"></div>
            <div class="avatar-item">
                <div class="avatar-circle">@initials</div>
                <div class="avatar-info">
                    <div class="avatar-name">@fullName</div>
                    <div class="avatar-role">@role</div>
                </div>
            </div>
            <a href="@Url.Action("Logout", "Account")" class="logout-item" onclick="closeDrawer()">
                <i class="nav-icon fa-solid fa-right-from-bracket"></i>
                <span class="nav-label">Logout</span>
            </a>
        </div>
    </div>

    <!-- Desktop Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><i class="fa-solid fa-utensils"></i></div>
            <span class="logo-text">MealLedger</span>
        </div>
        <nav class="nav-section">
            <a href="@Url.Action("Index", "Dashboard")"
               class="nav-item @(activePage == "Dashboard" ? "active" : "")">
                <i class="nav-icon fa-solid fa-house"></i>
                <span class="nav-label">Dashboard</span>
            </a>
            <a href="@Url.Action("Schedule", "Lunch")"
               class="nav-item @(activePage == "Lunch" ? "active" : "")">
                <i class="nav-icon fa-solid fa-utensils"></i>
                <span class="nav-label">Lunch</span>
            </a>
            <a href="@Url.Action("Index", "Calendar")"
               class="nav-item @(activePage == "Calendar" ? "active" : "")">
                <i class="nav-icon fa-regular fa-calendar"></i>
                <span class="nav-label">Calendar</span>
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Index", "Admin")"
                   class="nav-item @(activePage == "Admin" ? "active" : "")">
                    <i class="nav-icon fa-solid fa-shield-halved"></i>
                    <span class="nav-label">Admin</span>
                </a>
            }
        </nav>
        <div class="sidebar-bottom">
            <div class="nav-divider"></div>
            <div class="avatar-item">
                <div class="avatar-circle">@initials</div>
                <div class="avatar-info">
                    <div class="avatar-name">@fullName</div>
                    <div class="avatar-role">@role</div>
                </div>
            </div>
            <a href="@Url.Action("Logout", "Account")" class="logout-item">
                <i class="nav-icon fa-solid fa-right-from-bracket"></i>
                <span class="nav-label">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main -->
    <div class="main">
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="openDrawer()">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>@ViewData["Subtitle"]</p>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-user">
                    <div class="topbar-name">
                        <div class="name">@fullName</div>
                        <div class="role">@role</div>
                    </div>
                    <div class="topbar-avatar">@initials</div>
                </div>
                <a href="@Url.Action("Logout", "Account")" class="btn-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </header>

        <div class="page-content">
            @RenderBody()
        </div>

        <!-- Mobile Bottom Nav -->
        <nav class="bottom-nav">
            <div class="bottom-nav-inner">
                <a href="@Url.Action("Index", "Dashboard")"
                   class="bottom-nav-item @(activePage == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-house"></i><span>Home</span>
                </a>
                <a href="@Url.Action("Schedule", "Lunch")"
                   class="bottom-nav-item @(activePage == "Lunch" ? "active" : "")">
                    <i class="fa-solid fa-utensils"></i><span>Lunch</span>
                </a>
                <a href="@Url.Action("Index", "Calendar")"
                   class="bottom-nav-item @(activePage == "Calendar" ? "active" : "")">
                    <i class="fa-regular fa-calendar"></i><span>Calendar</span>
                </a>
                @if (isAdmin)
                {
                    <a href="@Url.Action("Index", "Admin")"
                       class="bottom-nav-item @(activePage == "Admin" ? "active" : "")">
                        <i class="fa-solid fa-shield-halved"></i><span>Admin</span>
                    </a>
                }
            </div>
        </nav>
    </div>

    <script>
        function openDrawer() {
            document.getElementById('drawer').classList.add('open');
            document.getElementById('overlay').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeDrawer() {
            document.getElementById('drawer').classList.remove('open');
            document.getElementById('overlay').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeDrawer();
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>